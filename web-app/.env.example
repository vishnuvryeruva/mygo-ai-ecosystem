# ═══════════════════════════════════════════════════════════
#  MYGO Web App — Environment Variables
#  Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════

# OpenAI (server-side only — do NOT prefix with NEXT_PUBLIC_)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1
CLAUDE_API_KEY=your-claude-key-here
CLAUDE_MODEL=claude-3-5-sonnet-latest
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-1.5-pro

# Backend URL for API proxy (used in next.config.js)
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001

# PostgreSQL Database (replaces SQLite + ChromaDB)
# Local dev:  postgresql://postgres:password@localhost:5432/mygo_ai
# Docker:     postgresql://postgres:postgres@localhost:5432/mygo_ai
# BTP:        postgresql://<user>:<pass>@<host>:<port>/<db>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mygo_ai

# Cloud ALM Configuration
CALM_API_ENDPOINT=https://your-tenant.us10.alm.cloud.sap/
CALM_TOKEN_URL=https://your-tenant.authentication.us10.hana.ondemand.com/oauth/token
CALM_CLIENT_ID=your-client-id
CALM_CLIENT_SECRET=your-client-secret
