applications:
  - name: mygo-backend
    docker:
      image: vishnuvryeruva98/mygo-backend:v202607151653
    memory: 512M
    disk_quota: 2G
    instances: 1
    routes:
      - route: mygo-backend-97415b8ftrial.cfapps.us10-001.hana.ondemand.com

  - name: mygo-frontend
    docker:
      image: vishnuvryeruva98/mygo-frontend:v202607151653
    memory: 1G
    disk_quota: 2G
    instances: 1
    routes:
      - route: mygo-frontend-97415b8ftrial.cfapps.us10-001.hana.ondemand.com
    env:
      NEXT_PUBLIC_BACKEND_URL: https://mygo-backend-97415b8ftrial.cfapps.us10-001.hana.ondemand.com